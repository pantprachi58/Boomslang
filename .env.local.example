# Email Configuration
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control

# Gmail / Google Workspace account for sending contact form emails
EMAIL_USER=support@boomslangnutrition.com

# Gmail App-Specific Password (not your regular Gmail password)
# Generate this from: https://myaccount.google.com/apppasswords
EMAIL_PASS=your_app_specific_password_here

# Where contact form submissions should be delivered
EMAIL_TO=support@boomslangnutrition.com

# Optional: Custom SMTP Configuration for non-Gmail providers
# Uncomment and configure these if support@boomslangnutrition.com is hosted
# by Hostinger, Zoho, cPanel, GoDaddy, or another mail provider.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=support@boomslangnutrition.com
# SMTP_PASS=your_smtp_password_here
